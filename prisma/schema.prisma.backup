generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int         @id @default(autoincrement())
  name      String?
  email     String      @unique
  password  String
  mobile    String?
  role      String      @default("user")
  createdAt DateTime?   @default(now())
  updatedAt DateTime?   @updatedAt
  lastName  String?
  Addresses Addresses[]
  Cart      Cart?
  Wishlist  Wishlist[]
  Orders    Order[]
}

model Addresses {
  id              Int     @id @default(autoincrement())
  createdAt DateTime?   @default(now())
  updatedAt DateTime?   @updatedAt
  name            String?
  mobile          String?
  alterNateMobile String?
  pinCode         String?
  city            String?
  state           String?
  address         String?
  landMark        String?
  addressType     String?
  userId          Int?
  user            User?   @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ProductCategory {
  id                   Int             @id @default(autoincrement())
  createdAt DateTime?   @default(now())
  updatedAt DateTime?   @updatedAt
  name                 String
  description          String?
  productCategoryImage String?
  productMaster        ProductMaster[]
}

model ProductMaster {
  id                Int             @id @default(autoincrement())
  createdAt DateTime?   @default(now())
  updatedAt DateTime?   @updatedAt
  productName       String
  productImage      String?
  productcategory   ProductCategory @relation(fields: [productCategoryId], references: [id])
  productCategoryId Int
  productLabel      String?
  productDesc       String?
  originalPrice     Float
  discountPrice     Float?
  productPrice      Float?
  ratings           Int?
  productStatus     Boolean         @default(true)
  CartItems         CartItem[]
  Wishlists         Wishlist[]
   productUom         Uom? @relation("ProductUom", fields: [productuomId], references: [id])
  productuomId       Int?
  productqty             Float?
  priceRange PriceRange[]
  OrderItems OrderItem[]
 
@@index([productStatus])
  @@index([productCategoryId])
}

model PriceRange {
  id        Int        @id @default(autoincrement())
  productId Int
  product   ProductMaster @relation(fields: [productId], references: [id], onDelete: Cascade)
  uomId     Int
  uom       Uom        @relation(fields: [uomId], references: [id], onDelete: Cascade)
  fromQty   Float
  toQty     Float
  price     Float
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Cart {
  id        Int        @id @default(autoincrement())
  
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int           @id @default(autoincrement())
  
  cartId    Int
  cart      Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId Int
  product   ProductMaster @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int           @default(1)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([cartId, productId])
}

model Wishlist {
  id        Int           @id @default(autoincrement())
  
  updatedAt DateTime?   @updatedAt
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   ProductMaster @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([userId, productId])
}



model Uom {
    id        Int           @id @default(autoincrement())
    createdAt DateTime?     @default(now())
    updatedAt DateTime?     @updatedAt
    name String
    shortCode String
    status Boolean @default(true)
    productUomProducts ProductMaster[] @relation("ProductUom")
    priceRange PriceRange[]
}

model Order {
  id               Int         @id @default(autoincrement())
  userId           Int
  user             User        @relation(fields: [userId], references: [id])
  totalAmount      Float
  status           String      @default("PENDING") // PENDING, PAID, FAILED
  razorpayOrderId  String?     @unique
  razorpayPaymentId String?    @unique
  razorpaySignature String?
  items            OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model OrderItem {
  id        Int           @id @default(autoincrement())
  orderId   Int
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   ProductMaster @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
